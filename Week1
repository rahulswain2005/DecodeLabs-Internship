    "---\n",
    "## Phase 1 — Strategic Imputation\n",
    "### Handle the Gaps. Don't just delete.\n",
    "\n",
    "> ⚠️ Warning: Listwise Deletion reduces statistical power.\n",
    "> Always prefer imputation when the missing pattern is explainable."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "d3e4f5a6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[ CR001 ] CouponCode — Missing Value Imputation\n",
      "  Missing BEFORE : 309\n",
      "  Missing AFTER  : 0\n",
      "  Records saved  : 309  (no rows deleted)\n",
      "  Method         : Constant Fill → 'NONE' (domain knowledge)\n",
      "  Status         : ✅ Resolved\n"
     ]
    }
   ],
   "source": [
    "# CR001 — Impute missing CouponCode with 'NONE'\n",
    "# Missing CouponCode simply means the customer did not apply any coupon.\n",
    "# Domain knowledge: a blank coupon field = no coupon used → fill with 'NONE'.\n",
    "\n",
    "before = df['CouponCode'].isnull().sum()\n",
    "\n",
    "df['CouponCode'] = df['CouponCode'].fillna('NONE')\n",
    "\n",
    "after = df['CouponCode'].isnull().sum()\n",
    "\n",
    "print(\"[ CR001 ] CouponCode — Missing Value Imputation\")\n",
    "print(f\"  Missing BEFORE : {before}\")\n",
    "print(f\"  Missing AFTER  : {after}\")\n",
    "print(f\"  Records saved  : {before}  (no rows deleted)\")\n",
    "print(f\"  Method         : Constant Fill → 'NONE' (domain knowledge)\")\n",
    "print(f\"  Status         : ✅ Resolved\")"
   ]
  },
